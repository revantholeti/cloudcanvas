{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "CloudCanvas Frontend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "export NVM_DIR=\"$HOME/.nvm\" && source \"$NVM_DIR/nvm.sh\" && nvm use 20 && npm run dev"],
      "port": 5173,
      "autoPort": true,
      "cwd": "frontend"
    },
    {
      "name": "CloudCanvas Backend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "source venv/bin/activate && uvicorn app.main:app --reload --port 8000"],
      "port": 8000,
      "cwd": "backend"
    }
  ]
}
